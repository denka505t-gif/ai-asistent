# agent-bot — переменные окружения
# Реальный файл .env лежит только на сервере: /home/agent/.agent/.env
# (создаётся один раз при установке, см. server/INSTALL-SERVER.md, пункт 7).
# Здесь — только образец имён переменных, без значений. В .gitignore .env* исключён из коммитов.

# --- Обязательные ---
BOT_TOKEN=
AGENT_HOME=/home/agent

# --- Владелец бота ---
# Telegram user id. Если не задан — бот привязывается к первому написавшему /start (auto-lock).
OWNER_ID=

# --- Голосовые сообщения ---
DEEPGRAM_API_KEY=

# --- Семантический поиск по памяти (Voyage AI) ---
VOYAGE_API_KEY=

# --- Опциональные интеграции (добавляются также через /secrets в самом боте) ---
GITHUB_TOKEN=
OPENROUTER_API_KEY=
NOTION_API_KEY=
OPENAI_API_KEY=
